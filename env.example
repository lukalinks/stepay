# Stepay - Environment Variables
# Copy to .env and fill in your values

# PostgreSQL (local, Neon, RDS, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=your-long-random-secret
# Encrypts Stellar wallet secrets at rest (generate: openssl rand -base64 32)
WALLET_ENCRYPTION_KEY=your-wallet-encryption-key
# Public URL of the app (used for secure cookies and password-reset links). No trailing slash.
# Local dev: use http://localhost:3000 (not your production URL)
AUTH_URL=http://localhost:3000
# Admin panel subdomain (production). Redirects stepay.pro/admin → admin.stepay.pro
ADMIN_URL=https://admin.stepay.pro
NEXT_PUBLIC_ADMIN_URL=https://admin.stepay.pro
# Share session cookies across stepay.pro and admin.stepay.pro (production only; omit locally)
# AUTH_COOKIE_DOMAIN=.stepay.pro
# Admin OTP login email (passwordless on admin.stepay.pro)
ADMIN_EMAIL=admin@stepay.pro
NEXT_PUBLIC_ADMIN_EMAIL=admin@stepay.pro

# Optional: SMS notifications for phone pay (otherwise logged server-side in dev)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1...
# Email — use Resend (free tier) OR Hostinger SMTP (free with your hosting plan)
# RESEND_API_KEY=re_...
# RESEND_FROM=Stepay <noreply@stepay.pro>
# Hostinger: create noreply@stepay.pro in hPanel → Emails, then:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@stepay.pro
# SMTP_PASS=your-mailbox-password
# SMTP_FROM=Stepay <noreply@stepay.pro>

# Lenco Mobile Money (https://api.lenco.co)
# In Lenco dashboard: Lenco Pay → APIs → copy Public Key and Secret Key.
# Secret Key is a Bearer token (often contains +, /, =) — NOT a 64-char hex SHA256 hash.
# LENCO_WEBHOOK_SECRET is separate: SHA256 of your API token (Lenco shows this for webhooks).
LENCO_ACCOUNT_ID=your-account-uuid
LENCO_API_URL=https://api.lenco.co/access/v2
# LENCO_PAYOUT_ENABLED=false  # Set to false to skip Lenco payout (for testing; manual payout required)
# LENCO_SKIP_DEPOSIT_VERIFICATION=true  # Dev only — never set in production
LENCO_PUBLIC_KEY=pub-xxx
LENCO_SECRET_KEY=xo+CAiijrIy9XvZCYyhjrv0fpSAL6CfU8CgA+up1NXqK
LENCO_WEBHOOK_SECRET=sha256-of-api-token

# Cron fallback for pending deposits (required in production)
CRON_SECRET=generate-a-long-random-secret

# Webhook URL to configure in Lenco Dashboard (for payment confirmations):
# https://stepay.vercel.app/api/hooks/lenco

# Stellar Mainnet - Funded wallet (must hold XLM and USDC for buy payouts)
PLATFORM_WALLET_SECRET=S...
PLATFORM_WALLET_PUBLIC_KEY=G...

# Optional: Override rates (ZMW per unit)
# XLM_RATE_ZMW=3.5
# USDC_RATE_ZMW=25
